{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signaldesk.local/schemas/signaldesk.backtest.setup_batch.v1.schema.json",
  "title": "SignalDesk backtest setup batch v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "symbol",
    "timeframe",
    "candle_count",
    "data_start",
    "data_end",
    "provider",
    "source",
    "labels",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "signaldesk.backtest.setup_batch.v1"
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "minLength": 1
    },
    "candle_count": {
      "type": "integer",
      "minimum": 1
    },
    "data_start": {
      "type": "string",
      "format": "date-time"
    },
    "data_end": {
      "type": "string",
      "format": "date-time"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "const": "cli_backtest_setup_batch"
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/setup_label_result"
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "setup_label_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup_label",
        "status",
        "signal_indices",
        "report",
        "unavailable_context"
      ],
      "properties": {
        "setup_label": {
          "type": "string",
          "enum": [
            "breakdown_watch",
            "breakout_watch",
            "moving_average_loss",
            "moving_average_reclaim",
            "relative_volume_spike"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "evaluated",
            "no_signals",
            "insufficient_history"
          ]
        },
        "signal_indices": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "report": {
          "description": "Nested signaldesk.backtest.setup_replay.v1 report when status is evaluated; otherwise null.",
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "schema_version",
                "setup_label",
                "metrics",
                "provenance",
                "limitations",
                "unavailable_context"
              ],
              "properties": {
                "schema_version": {
                  "const": "signaldesk.backtest.setup_replay.v1"
                }
              },
              "additionalProperties": true
            }
          ]
        },
        "unavailable_context": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
