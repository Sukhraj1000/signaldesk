{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signaldesk.local/schemas/signaldesk.backtest.setup_batch.v1.schema.json",
  "title": "SignalDesk backtest setup batch v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "symbol",
    "timeframe",
    "candle_count",
    "data_start",
    "data_end",
    "provider",
    "source",
    "provenance",
    "summary",
    "labels",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "signaldesk.backtest.setup_batch.v1"
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "minLength": 1
    },
    "candle_count": {
      "type": "integer",
      "minimum": 1
    },
    "data_start": {
      "type": "string",
      "format": "date-time"
    },
    "data_end": {
      "type": "string",
      "format": "date-time"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "const": "cli_backtest_setup_batch"
    },
    "labels": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/setup_label_result"
            },
            {
              "properties": {
                "setup_label": {
                  "const": "breakdown_watch"
                }
              },
              "required": [
                "setup_label"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/setup_label_result"
            },
            {
              "properties": {
                "setup_label": {
                  "const": "breakout_watch"
                }
              },
              "required": [
                "setup_label"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/setup_label_result"
            },
            {
              "properties": {
                "setup_label": {
                  "const": "moving_average_loss"
                }
              },
              "required": [
                "setup_label"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/setup_label_result"
            },
            {
              "properties": {
                "setup_label": {
                  "const": "moving_average_reclaim"
                }
              },
              "required": [
                "setup_label"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/setup_label_result"
            },
            {
              "properties": {
                "setup_label": {
                  "const": "relative_volume_spike"
                }
              },
              "required": [
                "setup_label"
              ]
            }
          ]
        }
      ],
      "items": false
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluated_label_count",
        "unavailable_label_count",
        "total_signal_count",
        "evaluation_coverage_rate",
        "average_data_availability_rate",
        "best_setup_label_by_event_usefulness",
        "best_event_usefulness",
        "limitations"
      ],
      "properties": {
        "evaluated_label_count": {
          "type": "integer",
          "minimum": 0
        },
        "unavailable_label_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_signal_count": {
          "type": "integer",
          "minimum": 0
        },
        "evaluation_coverage_rate": {
          "type": "string",
          "pattern": "^-?\\d+(?:\\.\\d+)?$"
        },
        "average_data_availability_rate": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^-?\\d+(?:\\.\\d+)?$"
        },
        "best_setup_label_by_event_usefulness": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "breakdown_watch",
            "breakout_watch",
            "moving_average_loss",
            "moving_average_reclaim",
            "relative_volume_spike",
            null
          ]
        },
        "best_event_usefulness": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^-?\\d+(?:\\.\\d+)?$"
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "source",
        "generated_at",
        "timeframe",
        "inputs",
        "warnings"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "const": "cli_backtest_setup_batch"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "timeframe": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "symbol",
            "setup_labels",
            "horizons",
            "walk_forward_window_size"
          ],
          "properties": {
            "symbol": {
              "type": "string",
              "minLength": 1
            },
            "setup_labels": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "breakdown_watch",
                  "breakout_watch",
                  "moving_average_loss",
                  "moving_average_reclaim",
                  "relative_volume_spike"
                ]
              }
            },
            "horizons": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 1
              }
            },
            "walk_forward_window_size": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "setup_label_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup_label",
        "status",
        "setup_label_detail",
        "signal_indices",
        "report",
        "unavailable_context"
      ],
      "properties": {
        "setup_label": {
          "type": "string",
          "enum": [
            "breakdown_watch",
            "breakout_watch",
            "moving_average_loss",
            "moving_average_reclaim",
            "relative_volume_spike"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "evaluated",
            "no_signals",
            "insufficient_history"
          ]
        },
        "signal_indices": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "report": {
          "description": "Nested signaldesk.backtest.setup_replay.v1 report when status is evaluated; otherwise null.",
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "signaldesk.backtest.setup_replay.v1.schema.json"
            }
          ]
        },
        "unavailable_context": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "setup_label_detail": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "setup_label",
            "description",
            "derivation",
            "lookback_candles",
            "minimum_candles"
          ],
          "properties": {
            "setup_label": {
              "type": "string",
              "enum": [
                "breakdown_watch",
                "breakout_watch",
                "moving_average_loss",
                "moving_average_reclaim",
                "relative_volume_spike"
              ]
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "derivation": {
              "type": "string",
              "minLength": 1
            },
            "lookback_candles": {
              "type": "integer",
              "minimum": 1
            },
            "minimum_candles": {
              "type": "integer",
              "minimum": 2
            }
          }
        }
      }
    }
  }
}
