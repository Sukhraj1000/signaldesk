{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:signaldesk:schema:backtest-setup-labels-v1",
  "title": "SignalDesk backtest setup labels",
  "description": "Machine-readable discovery output from signaldesk backtest setup-labels. Lists deterministic research setup labels only; no recommendations, broker instructions, or live-trading behavior are permitted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "setup_labels",
    "setup_label_details",
    "default_provider",
    "source",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "signaldesk.backtest.setup_labels.v1"
    },
    "setup_labels": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {
          "const": "breakdown_watch"
        },
        {
          "const": "breakout_watch"
        },
        {
          "const": "moving_average_loss"
        },
        {
          "const": "moving_average_reclaim"
        },
        {
          "const": "relative_volume_spike"
        }
      ],
      "items": false
    },
    "default_provider": {
      "const": "local-fixture"
    },
    "source": {
      "const": "deterministic_candle_rules"
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "setup_label_details": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "setup_label",
          "description",
          "derivation",
          "lookback_candles",
          "minimum_candles"
        ],
        "properties": {
          "setup_label": {
            "type": "string",
            "enum": [
              "breakdown_watch",
              "breakout_watch",
              "moving_average_loss",
              "moving_average_reclaim",
              "relative_volume_spike"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "derivation": {
            "type": "string",
            "minLength": 1
          },
          "lookback_candles": {
            "type": "integer",
            "minimum": 1
          },
          "minimum_candles": {
            "type": "integer",
            "minimum": 2
          }
        }
      }
    }
  }
}
